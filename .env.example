# VibeReview environment configuration template.
# Copy this file to '.env' and fill in the values.

# Google Cloud Settings
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Google GenAI API Key (only for local AI Studio development, if Vertex AI is disabled)
# GOOGLE_API_KEY=your-api-key

# Zero Ambient Authority & SPIFFE identity workload provider socket path
SPIFFE_ENDPOINT_SOCKET=unix:///var/run/spiffe-workload-api.sock

# Spanner Graph Configuration
SPANNER_INSTANCE=vibe-review-instance
SPANNER_DATABASE=vibe-review-graph-db

# GitHub MCP Server Configuration (Remote A2A Extension)
# Copy your GitHub Personal Access Token here to authorize MCP repository access
GITHUB_TOKEN=your-github-personal-access-token
# GITHUB_PERSONAL_ACCESS_TOKEN=your-github-personal-access-token
# GITHUB_MCP_COMMAND=npx
# GITHUB_MCP_ARGS=-y,@modelcontextprotocol/server-github

# Spanner Graph MCP Server Configuration (Local Data Gateway)
# SPANNER_MCP_COMMAND=npx
# SPANNER_MCP_ARGS=-y,@krzko/google-cloud-mcp,spanner

